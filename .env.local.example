# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Calendly embed (public URLs only — no Scheduling API)
# Event link: https://calendly.com/your-handle/event-type (or https://your-handle.calendly.com/...)
NEXT_PUBLIC_CALENDLY_EVENT_URL=https://calendly.com/your-handle/30min

# Branding: hex without # (Calendly query params)
NEXT_PUBLIC_CALENDLY_PRIMARY_COLOR=5A9A9A
NEXT_PUBLIC_CALENDLY_TEXT_COLOR=1F2937
NEXT_PUBLIC_CALENDLY_BACKGROUND_COLOR=FFFFFF

# Legal: only set true with sign-off (adds hide_gdpr_banner=1 to embed URL)
NEXT_PUBLIC_CALENDLY_HIDE_GDPR_BANNER=false

# Set to false to disable inline/popup script and show “open in new tab” only
NEXT_PUBLIC_CALENDLY_EMBED_ENABLED=true

# Optional: Calendly “invitee question” UUID to receive the site’s 5-step summary as one pre-filled answer
# (from Calendly embed / browser devtools — only if that question exists on the event type)
# NEXT_PUBLIC_CALENDLY_SUMMARY_CUSTOM_QUESTION_ID=
